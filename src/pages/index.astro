---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import HeroPattern from '../components/HeroPattern.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const featured = posts[0];
const recent = posts.slice(1, 7);

function stampOf(date: Date): string {
    return date.toISOString().slice(0, 10).replace(/-/g, '.');
}
---

<!doctype html>
<html lang="en">
    <head>
        <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    </head>
    <body>
        <Header path="~/den" />
        <main class="home">
            <header class="mast">
                <p class="mast__kicker">dispatches from the den</p>
                <h1 class="mast__title">Worldsmythe's Den</h1>
                <p class="mast__sub">{SITE_DESCRIPTION}</p>
                <div class="mast__band" aria-hidden="true"><span class="mast__fill"></span></div>
            </header>

            {featured && (
                <article class="feat">
                    <div class="shead">latest transmission <span class="n">ENTRY {String(posts.length).padStart(3, '0')}</span></div>
                    <a class="feat__media" href={`/blog/${featured.id}/`} transition:name={`hero-${featured.id}`}>
                        {featured.data.heroImage ? (
                            <Image width={1100} height={460} src={featured.data.heroImage} alt="" loading="eager" fetchpriority="high" />
                        ) : (
                            <HeroPattern seed={featured.id} label={featured.data.title} />
                        )}
                    </a>
                    <div class="log__meta" style="margin-top:18px" transition:name={`meta-${featured.id}`}>
                        <span class="tag tag--lime">SIGNAL</span>
                        <span>{stampOf(featured.data.pubDate)}</span>
                    </div>
                    <h2 class="feat__title" transition:name={`title-${featured.id}`}><a href={`/blog/${featured.id}/`}>{featured.data.title}</a></h2>
                    <p class="feat__dek" transition:name={`dek-${featured.id}`}>{featured.data.description}</p>
                </article>
            )}

            {recent.length > 0 && (
                <section class="recents">
                    <div class="shead">recent entries <span class="n">{recent.length} OF {posts.length}</span></div>
                    <ul class="log">
                        {recent.map((post, i) => (
                            <li class="log__row">
                                <div class="log__idx">{String(posts.length - 1 - i).padStart(3, '0')}</div>
                                <div class="log__body">
                                    <div class="log__meta" transition:name={`meta-${post.id}`}>
                                        <span class="tag tag--lime">SIGNAL</span>
                                        <span>{stampOf(post.data.pubDate)}</span>
                                    </div>
                                    <h3 class="log__title" transition:name={`title-${post.id}`}><a href={`/blog/${post.id}/`}>{post.data.title}</a></h3>
                                    <p class="log__ex" transition:name={`dek-${post.id}`}>{post.data.description}</p>
                                </div>
                            </li>
                        ))}
                    </ul>
                </section>
            )}
        </main>
        <Footer />
    </body>
</html>
<style>
    .home {
        width: var(--content-wide);
        max-width: 100%;
        margin: 0 auto;
        padding: 0 0 3em;
    }

    .mast { padding: clamp(24px, 4vw, 46px) var(--gut) 0; }
    .mast__kicker {
        font-family: var(--font-mono-stack);
        font-size: 0.72rem;
        letter-spacing: 0.34em;
        text-transform: uppercase;
        color: var(--lime);
        margin: 0 0 16px;
    }
    .mast__title {
        font-family: var(--font-mono-stack);
        font-weight: 700;
        font-size: clamp(26px, 8.2vw, 86px);
        line-height: 1;
        letter-spacing: -0.02em;
        text-transform: uppercase;
        white-space: nowrap;
        margin: 0;
        color: var(--ink);
        text-shadow: 0 0 22px rgba(152, 224, 74, 0.18);
    }
    .mast__sub {
        font-family: var(--font-body-stack);
        font-style: italic;
        color: var(--ink-dim);
        font-size: clamp(16px, 2.1vw, 22px);
        max-width: 54ch;
        margin: 18px 0 0;
    }
    .mast__band { height: 46px; margin: 26px 0 0; overflow: hidden; }
    .mast__fill {
        display: block;
        width: 100%;
        height: 100%;
        color: var(--ink);
        background-image:
            linear-gradient(45deg, currentColor 25%, transparent 25% 75%, currentColor 75%),
            linear-gradient(45deg, currentColor 25%, transparent 25% 75%, currentColor 75%);
        background-size: 3px 3px;
        background-position: 0 0, 1.5px 1.5px;
        -webkit-mask-image: linear-gradient(to bottom, #000, transparent);
                mask-image: linear-gradient(to bottom, #000, transparent);
    }

    .feat { padding: var(--gut); border-top: var(--rule) solid var(--line); margin-top: clamp(22px, 4vw, 40px); }
    .feat__media { display: block; margin: 0; border: none; }
    .feat__media :global(img) { width: 100%; height: auto; display: block; border: var(--rule) solid var(--line); }
    .feat__media:hover { background: transparent; }
    .feat__title {
        font-family: var(--font-mono-stack);
        font-weight: 600;
        text-transform: uppercase;
        font-size: clamp(26px, 3.4vw, 40px);
        line-height: 1.02;
        letter-spacing: -0.01em;
        margin: 14px 0 0;
    }
    .feat__title a { color: var(--ink); }
    .feat__title a:hover { color: var(--bg); background: var(--amber); }
    .feat__dek { font-family: var(--font-body-stack); font-style: italic; font-size: 1.05rem; color: var(--ink-dim); margin: 16px 0 0; max-width: 62ch; }

    .recents { padding: var(--gut) var(--gut) 0; }
</style>
