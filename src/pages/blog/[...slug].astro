---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
	return posts.map((post, i) => ({
		params: { slug: post.id },
		props: {
			...post,
			prev: posts[i + 1]
				? { id: posts[i + 1].id, title: posts[i + 1].data.title }
				: undefined,
			next: posts[i - 1]
				? { id: posts[i - 1].id, title: posts[i - 1].data.title }
				: undefined,
		},
	}));
}

type Props = CollectionEntry<'blog'> & {
	prev?: { id: string; title: string };
	next?: { id: string; title: string };
};

const { prev, next, ...post } = Astro.props;
const { Content, headings } = await render(post as CollectionEntry<'blog'>);
---

<BlogPost {...post.data} slug={post.id} ogImage={`/og/${post.id}.png`} headings={headings} prev={prev} next={next}>
	<Content />
</BlogPost>
